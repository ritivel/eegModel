# Source this file before running any of the scripts in this directory:
#   cp .env.example .env && vim .env && source .env
#
# Values below are the actuals for the 2026-W19 reservation. Update for
# future reservations.

# ---- AWS region / account ------------------------------------------------
export AWS_REGION="ap-south-1"
export AWS_DEFAULT_REGION="ap-south-1"
export AWS_ACCOUNT_ID="139156132535"

# ---- the reservation -----------------------------------------------------
# Capacity Block offering (from `aws ec2 describe-capacity-block-offerings`).
# Run scripts/describe-offerings.sh to refresh.
export CB_OFFERING_ID="cb-06acabbeb025ff1d3"
export CB_INSTANCE_TYPE="p5.48xlarge"
export CB_DURATION_HOURS="168"
export CB_AZ="ap-south-1a"
export CB_SUBNET_ID="subnet-062d8f2ac72af66c1"      # default-for-az subnet in ap-south-1a
export CB_VPC_ID="vpc-03b70f34f216ded41"
export CB_START_DATE="2026-05-05T11:30:00Z"
export CB_END_DATE="2026-05-12T11:30:00Z"
export CB_UPFRONT_FEE_USD="5285.95"

# Filled in by purchase-capacity-block.sh after purchase succeeds. Leave
# blank until then.
export CB_RESERVATION_ID=""

# ---- launch identity -----------------------------------------------------
export EC2_KEY_NAME="eeg-mumbai-2026w19"
export EC2_KEY_PATH="$HOME/.ssh/eeg-mumbai-2026w19.pem"
export EC2_SG_ID="sg-0a7017c9b48c300ca"
export EC2_AMI_ID="ami-0eb5a4f0d81f671e3"            # DLAMI PyTorch 2.7 Ubuntu 22.04, 2026-04-28
export EC2_NAME_TAG="eeg-mumbai-2026w19"
export EC2_INSTANCE_PROFILE=""                       # optional — if you want s3:* via instance role

# ---- storage -------------------------------------------------------------
# Permanent warehouse (us-west-2, persists across weeks/regions)
export S3_WAREHOUSE_BUCKET="eegmodel-warehouse"
export S3_WAREHOUSE_REGION="us-west-2"

# This-week regional cache (ap-south-1, lives only while reservation is active)
export S3_MUMBAI_BUCKET="eeg-mumbai-139156132535"
export S3_MUMBAI_REGION="ap-south-1"

# What the GPU box sees as its derived/ source. The exp03 storage module
# reads $EXP03_S3_BUCKET if set; otherwise falls back to the warehouse.
export EXP03_S3_BUCKET="${S3_MUMBAI_BUCKET}"
export EXP03_S3_REGION="${S3_MUMBAI_REGION}"

# ---- repo + working dir on the GPU box ----------------------------------
export REMOTE_REPO_URL="https://github.com/ritivel/eegModel.git"
export REMOTE_REPO_BRANCH="main"
export REMOTE_HOME="/home/ubuntu"
export REMOTE_DATA_ROOT="/opt/dlami/nvme/eeg"

# ---- secrets the GPU box needs (set in your local shell, NOT committed) -
# Uncomment + set on your local Mac before running launch-instance.sh; the
# launch script forwards these into the bootstrap user-data.
# export WANDB_API_KEY="..."
# export HF_TOKEN="..."
# export NEDC_TUH_USER="..."   # only if you'll run tuh-rsync this week
